{
  "name": "bartz-analyzer",
  "version": "4.0.0",
  "private": true,
  "main": "cjs-main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite --port 5174 --strictPort",
    "dev:main": "wait-on http://localhost:5174 && cross-env VITE_DEV=1 electron .",
    "build": "vite build",
    "dist:win": "npm run build && electron-builder --win",
    "start": "electron .",
    "test": "vitest run",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "build": {
    "productName": "Bartz Analyzer",
    "appId": "com.bartz.analyzer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/**/*",
      "electron/**/*",
      "csv/**/*",
      "cjs-main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      "Muxarabi/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "node_modules/app-builder-lib/templates/icons/proton-native/proton-native.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bartz Analyzer"
    }
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitejs/plugin-react-swc": "^3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.7.0",
    "eslint": "^8.57.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dxf-parser": "^1.1.2",
    "electron-store": "^11.0.2",
    "fast-xml-parser": "^5.2.5",
    "fs-extra": "^11.3.1",
    "lucide-react": "^0.542.0",
    "react": "^18",
    "react-dom": "^18",
    "react-router-dom": "^6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2"
  }
}
